# Production Environment Variables
# Copy this file to .env.production and fill in actual values

# ============ DATABASE ============
DATABASE_URL="postgresql://postgres:SECURE_PASSWORD@your-db-host:5432/smart_pos"
DB_USER="postgres"
DB_PASSWORD="SECURE_PASSWORD"

# ============ REDIS ============
REDIS_URL="redis://:SECURE_PASSWORD@your-redis-host:6379"
REDIS_PASSWORD="SECURE_PASSWORD"

# ============ JWT ============
JWT_SECRET="YOUR_VERY_SECURE_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG"
JWT_REFRESH_SECRET="YOUR_VERY_SECURE_REFRESH_SECRET_AT_LEAST_32_CHARACTERS_LONG"
JWT_EXPIRY="24h"
JWT_REFRESH_EXPIRY="7d"

# ============ ENCRYPTION ============
ENCRYPTION_KEY="YOUR_32_CHARACTER_ENCRYPTION_KEY_EXACTLY"

# ============ OPENAI ============
OPENAI_API_KEY="sk-YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4"

# ============ M-PESA ============
MPESA_CONSUMER_KEY="YOUR_MPESA_CONSUMER_KEY"
MPESA_CONSUMER_SECRET="YOUR_MPESA_CONSUMER_SECRET"
MPESA_SHORTCODE="YOUR_MPESA_SHORTCODE"
MPESA_PASSKEY="YOUR_MPESA_PASSKEY"
MPESA_ENVIRONMENT="production"

# ============ APPLICATION ============
NODE_ENV="production"
PORT="3000"
NEXT_PUBLIC_API_URL="https://your-domain.com"

# ============ LOGGING ============
LOG_LEVEL="info"
AUDIT_LOG_RETENTION_DAYS="365"

# ============ MULTI-BRANCH ============
ENABLE_MULTI_BRANCH="true"
SYNC_INTERVAL_MS="5000"

# ============ OFFLINE MODE ============
ENABLE_OFFLINE_MODE="true"
OFFLINE_SYNC_BATCH_SIZE="100"

# ============ PERFORMANCE ============
CACHE_TTL_SECONDS="300"
PRODUCT_SEARCH_TIMEOUT_MS="100"
INVENTORY_UPDATE_TIMEOUT_MS="100"

# ============ MONITORING ============
SENTRY_DSN="https://YOUR_SENTRY_DSN"
DATADOG_API_KEY="YOUR_DATADOG_API_KEY"

# ============ EMAIL ============
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="YOUR_APP_PASSWORD"
SMTP_FROM="noreply@smartpos.com"

# ============ BACKUP ============
BACKUP_ENABLED="true"
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="30"
